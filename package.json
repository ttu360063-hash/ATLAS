{
  "name": "atlas-desktop",
  "version": "1.0.0",
  "description": "ATLAS Desktop - Aplicativo de chat AI",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "node node_modules/vite/bin/vite.js build",
    "build:electron": "npm run build && electron-builder",
    "dist": "npm run build:electron",
    "electron": "electron .",
    "install-deps": "npm install"
  },
  "build": {
    "appId": "com.atlas.desktop",
    "productName": "ATLAS Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "node_modules/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.0",
    "vite": "^4.4.0",
    "wait-on": "^7.0.1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
